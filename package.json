{
  "name": "jarvis",
  "version": "1.0.1",
  "description": "J.A.R.V.I.S. - Just A Rather Very Intelligent System",
  "author": "Dubis1cz",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "publish": "electron-builder --win --x64 --publish always"
  },
  "build": {
    "appId": "com.dubis1cz.jarvis",
    "productName": "JARVIS",
    "compression": "maximum",
    "publish": {
      "provider": "github",
      "owner": "Dubis1cz",
      "repo": "Jarvis"
    },
    "win": {
      "target": "nsis",
      "icon": "src/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "shortcutName": "JARVIS",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      { "from": "jarvis.html",  "to": "jarvis.html"  },
      { "from": "login.html",   "to": "login.html"   },
      { "from": "server.py",    "to": "server.py"    },
      { "from": "python-embed/", "to": "python-embed/", "filter": ["**/*"] }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}

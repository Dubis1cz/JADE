{
  "name": "jade",
  "version": "1.1.2",
  "description": "J.A.D.E. - JDStudios Artificial Digital Executive",
  "author": "Dubis1cz",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "publish": "electron-builder --win --x64 --publish always"
  },
  "build": {
    "appId": "com.dubis1cz.jade",
    "productName": "JADE",
    "compression": "maximum",
    "publish": {
      "provider": "github",
      "owner": "Dubis1cz",
      "repo": "Jarvis"
    },
    "win": {
      "target": "nsis",
      "icon": "src/icon.ico",
      "artifactName": "JADE-Setup-${version}.exe"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": true,
      "shortcutName": "JADE",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      { "from": "jade.html",  "to": "jade.html"  },
      { "from": "login.html",   "to": "login.html"   },
      { "from": "server.py",    "to": "server.py"    },
      { "from": "python-embed/", "to": "python-embed/", "filter": ["**/*"] }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
